<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="recommendationHistory">

    <!-- id (AUTO_INCREMENT) and created_at (DEFAULT CURRENT_TIMESTAMP) are DB-generated. -->
    <insert id="insertHistory"
            parameterType="com.mcmp.costbe.llm_recommender.model.RecommendationHistory">
        INSERT INTO recommendation_history (ns_id, instance_id, recommendation, response_json)
        VALUES (#{nsId}, #{instanceId}, #{recommendation}, #{responseJson})
    </insert>

</mapper>
